# ─────────────────────────────────────────────────────
#  Nemotron · Dev Agent — Variables d'environnement
#  Copier en .env et remplir les valeurs
# ─────────────────────────────────────────────────────

# Clé API OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mot de passe de connexion à l'interface Web
APP_PASSWORD=devagent

# Clé secrète Flask (OBLIGATOIRE en production — générer avec: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme_en_production_avec_une_cle_aleatoire

# Base de données (SQLite par défaut, PostgreSQL en prod)
# SQLite (local/Termux) :
DATABASE_URL=sqlite:///devagent.db
# PostgreSQL (Render) :
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Répertoire des workspaces
WORKSPACE_ROOT=./workspaces

# Cache SQLite
CACHE_DB_PATH=tool_cache.db

# Nombre max d'étapes de l'agent (défaut 15)
MAX_STEPS=15

# Activer le mode debug Flask (dev uniquement — NE JAMAIS mettre true en prod)
FLASK_DEBUG=false

# Port (Render l'injecte automatiquement)
# PORT=5000
